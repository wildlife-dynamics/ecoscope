{%- set MAP_TYPES = ["events_map", "event_count_map"] -%}
{%- set ns = namespace(enabled=[], row=0) -%}
{%- if include_bar_chart == "yes" -%}{%- set ns.enabled = ns.enabled + ["bar_chart"] -%}{%- endif -%}
{%- if include_events_map == "yes" -%}{%- set ns.enabled = ns.enabled + ["events_map"] -%}{%- endif -%}
{%- if include_pie_chart == "yes" -%}{%- set ns.enabled = ns.enabled + ["pie_chart"] -%}{%- endif -%}
{%- if include_event_count_map == "yes" -%}{%- set ns.enabled = ns.enabled + ["event_count_map"] -%}{%- endif -%}
{%- if include_events_table == "yes" -%}{%- set ns.enabled = ns.enabled + ["events_table"] -%}{%- endif -%}
[
{%- for i in range(ns.enabled | length) %}
{%-   set wtype = ns.enabled[i] %}
{%-   set widget_id = i %}
{%-   set is_left = (i % 2 == 0) %}
{%-   set is_last = (i == (ns.enabled | length) - 1) %}
{%-   set is_solo = is_left and is_last %}
{%-   if is_left %}
{%-     set ns.row = i // 2 %}
{%-   endif %}
{%-   if is_solo %}
{%-     set x = 0 %}
{%-     set w = 10 %}
{%-     set minW = 5 %}
{%-   elif is_left %}
{%-     set right_type = ns.enabled[i + 1] %}
{%-     set left_is_map = wtype in MAP_TYPES %}
{%-     set right_is_map = right_type in MAP_TYPES %}
{%-     if left_is_map and not right_is_map %}
{%-       set x = 0 %}
{%-       set w = 6 %}
{%-       set minW = 5 %}
{%-     elif not left_is_map and right_is_map %}
{%-       set x = 0 %}
{%-       set w = 4 %}
{%-       set minW = 4 %}
{%-     elif left_is_map and right_is_map %}
{%-       set x = 0 %}
{%-       set w = 5 %}
{%-       set minW = 5 %}
{%-     else %}
{%-       set x = 0 %}
{%-       set w = 5 %}
{%-       set minW = 4 %}
{%-     endif %}
{%-   else %}
{%-     set left_type = ns.enabled[i - 1] %}
{%-     set left_is_map = left_type in MAP_TYPES %}
{%-     set right_is_map = wtype in MAP_TYPES %}
{%-     if left_is_map and not right_is_map %}
{%-       set x = 6 %}
{%-       set w = 4 %}
{%-       set minW = 4 %}
{%-     elif not left_is_map and right_is_map %}
{%-       set x = 4 %}
{%-       set w = 6 %}
{%-       set minW = 5 %}
{%-     elif left_is_map and right_is_map %}
{%-       set x = 5 %}
{%-       set w = 5 %}
{%-       set minW = 5 %}
{%-     else %}
{%-       set x = 5 %}
{%-       set w = 5 %}
{%-       set minW = 4 %}
{%-     endif %}
{%-   endif %}
  {
    "i": {{ widget_id }},
    "x": {{ x }},
    "y": {{ ns.row * 10 }},
    "w": {{ w }},
    "h": 10,
    "minW": {{ minW }},
    "static": false
  }{% if not is_last %},{% endif %}
{%- endfor %}
]
