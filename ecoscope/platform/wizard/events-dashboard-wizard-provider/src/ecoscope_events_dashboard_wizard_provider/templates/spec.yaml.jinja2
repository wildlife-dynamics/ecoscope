{#- Macros to emit wt-compiler ${{ }} references without Jinja2 evaluating them -#}
{%- macro wf(task_id) -%}${{ '{{' }} workflow.{{ task_id }}.return {{ '}}' }}{%- endmacro -%}
{%- macro env(var_name) -%}${{ '{{' }} env.{{ var_name }} {{ '}}' }}{%- endmacro -%}
{#- Enabled flags from provider answers; titles are in context as <wtype>_title -#}
{%- set bar_enabled = include_bar_chart == "yes" -%}
{%- set map_enabled = include_events_map == "yes" -%}
{%- set pie_enabled = include_pie_chart == "yes" -%}
{%- set fd_enabled  = include_event_count_map == "yes" -%}
{%- set tbl_enabled = include_events_table == "yes" -%}
id: {{ workflow_id }}

requirements:
  - name: "ecoscope-platform"
    version: ">=2.11.3,<3"
    channel: "https://repo.prefix.dev/ecoscope-workflows/"
{% for req in requirements %}
  - name: "{{ req.name }}"
{% if req.req_type == 'conda' %}
    version: "{{ req.version }}"
    channel: "{{ req.channel }}"
{% elif req.req_type == 'local path' %}
    path: "{{ req.path }}"
{% if req.editable == 'true' %}
    editable: true
{% endif %}
{% elif req.req_type == 'url' %}
    url: "{{ req.url }}"
{% elif req.req_type == 'git' %}
    git: "{{ req.git }}"
{% if req.git_ref_type == 'rev' %}
    rev: "{{ req.git_ref_value }}"
{% elif req.git_ref_type == 'branch' %}
    branch: "{{ req.git_ref_value }}"
{% elif req.git_ref_type == 'tag' %}
    tag: "{{ req.git_ref_value }}"
{% endif %}
{% endif %}
{% endfor %}

rjsf-overrides:
  properties:
    get_events_data.properties.event_types.ecoscope:transform:
      - transformer: EarthRangerEnumResolver
        transformer_kws:
          type: event_type
          depends_on: properties.er_client_name.properties.data_source.properties.name
    groupers.properties.groupers.ecoscope:transform:
      - transformer: EarthRangerEnumResolver
        transformer_kws:
          type: spatial_feature_group
          depends_on: properties.er_client_name.properties.data_source.properties.name
  $defs:
    ValueGrouper.properties.index_name.oneOf:
      - const: event_category
        title: Event Type Category
      - const: event_type
        title: Event Type
      - const: reported_by_name
        title: Reported By Name
  uiSchema:
    groupers.groupers.items.anyOf:
      - ui:options:
          label: false
      - ui:options:
          label: false
      - ui:options:
          label: false
    get_events_data.event_types.ui:options.displayLabel: false
    filter_events.filter_point_coords.items.ui:options.label: false
    base_map_defs.base_maps.items.ui:options.label: false
{% if fd_enabled %}
    {{ event_count_map_title }}.events_meshgrid.auto_scale_or_custom_cell_size:
      anyOf:
        - ui:help: Auto-scale for an optimized grid cell size based the workflow data or Customize to set a specific grid cell size.
          ui:options:
            label: false
          auto_scale_or_custom:
            ui:widget: hidden
        - ui:options:
            label: false
          auto_scale_or_custom:
            ui:widget: hidden
      auto_scale_or_custom:
        ui:widget: hidden
{% endif %}

task-instance-defaults:
  skipif:
    conditions:
      - any_is_empty_df
      - any_dependency_skipped

workflow:
  - name: Workflow Details
    id: workflow_details
    task: set_workflow_details
  - name: Data Source
    id: er_client_name
    task: set_er_connection
  - name: Time Range
    id: time_range
    task: set_time_range
    partial:
      time_format: '%d %b %Y %H:%M:%S'
  - name: Extract Timezone Selection
    id: get_timezone
    task: get_timezone_from_time_range
    partial:
      time_range: {{ wf("time_range") }}
  - name: Event Types
    id: get_events_data
    task: get_events
    partial:
      client: {{ wf("er_client_name") }}
      time_range: {{ wf("time_range") }}
      event_columns:
        - id
        - time
        - event_type
        - event_category
        - reported_by
        - serial_number
        - geometry
      raise_on_empty: false
      include_details: false
      include_updates: false
      include_related_events: false
      include_display_values: true
  - name: Convert to timezone
    id: convert_to_user_timezone
    task: convert_values_to_timezone
    partial:
      df: {{ wf("get_events_data") }}
      timezone: {{ wf("get_timezone") }}
      columns:
        - time
  - name: Extract reported_by_name from Events
    id: extract_reported_by
    task: extract_value_from_json_column
    partial:
      df: {{ wf("convert_to_user_timezone") }}
      column_name: reported_by
      field_name_options:
        - name
      output_type: str
      output_column_name: reported_by_name
  - name: Group Data
    id: groupers
    task: set_groupers
  - task: extract_spatial_grouper_feature_group_names
    id: spatial_group_ids
    partial:
      groupers: {{ wf("groupers") }}
  - task: get_spatial_features_group
    id: fetch_all_spatial_feature_groups
    partial:
      client: {{ wf("er_client_name") }}
    map:
      argnames: spatial_features_group_name
      argvalues: {{ wf("spatial_group_ids") }}
  - task: resolve_spatial_feature_groups_for_spatial_groupers
    id: resolved_groupers
    skipif:
      conditions:
        - never
    partial:
      groupers: {{ wf("groupers") }}
      spatial_feature_groups: {{ wf("fetch_all_spatial_feature_groups") }}
  - name: Event Location Filter
    id: filter_events
    task: apply_reloc_coord_filter
    partial:
      df: {{ wf("extract_reported_by") }}
      roi_gdf: null
      roi_name: null
      reset_index: true
  - name: Add temporal index to Events
    id: events_add_temporal_index
    task: add_temporal_index
    partial:
      df: {{ wf("filter_events") }}
      time_col: time
      groupers: {{ wf("resolved_groupers") }}
      cast_to_datetime: true
      format: mixed
  - name: Add spatial index to Events
    id: events_add_spatial_index
    task: add_spatial_index
    partial:
      gdf: {{ wf("events_add_temporal_index") }}
      groupers: {{ wf("resolved_groupers") }}
  - name: Events Colormap
    id: events_colormap
    task: apply_color_map
    partial:
      df: {{ wf("events_add_spatial_index") }}
      input_column_name: event_type
      colormap: tab20b
      output_column_name: event_type_colormap
{% if bar_enabled %}
  - name: Set Bar Chart Title
    id: set_bar_chart_title
    task: set_string_var
    partial:
      var: {{ bar_chart_title }}
{% endif %}
{% if map_enabled %}
  - name: Set Events Map Title
    id: set_events_map_title
    task: set_string_var
    partial:
      var: {{ events_map_title }}
{% endif %}
{% if pie_enabled %}
  - name: Set Pie Chart Title
    id: set_pie_chart_title
    task: set_string_var
    partial:
      var: {{ pie_chart_title }}
{% endif %}
{% if fd_enabled %}
  - name: Set Event Count Map Title
    id: set_fd_map_title
    task: set_string_var
    partial:
      var: {{ event_count_map_title }}
{% endif %}
{% if tbl_enabled %}
  - name: Set Events Table Title
    id: set_events_table_title
    task: set_string_var
    partial:
      var: {{ events_table_title }}
{% endif %}
  - name: Split Events by Group
    id: split_event_groups
    task: split_groups
    partial:
      df: {{ wf("events_colormap") }}
      groupers: {{ wf("resolved_groupers") }}
{% if bar_enabled %}
  - title: {{ bar_chart_title }}
    type: task-group
    description: The bar chart shows how many events of different types occurred over time. Choose the time interval for the x-axis to control how event counts are summarized over time.
    tasks:
      - name: null
        id: events_bar_chart
        task: draw_time_series_bar_chart
        partial:
          x_axis: time
          y_axis: event_type_display
          category: event_type_display
          agg_function: count
          color_column: event_type_colormap
          plot_style:
            xperiodalignment: middle
          layout_style: null
          widget_id: {{ wf("set_bar_chart_title") }}
        mapvalues:
          argnames: dataframe
          argvalues: {{ wf("split_event_groups") }}
      - name: Persist Bar Chart as Text
        id: events_bar_chart_html_url
        task: persist_text
        partial:
          root_path: {{ env("ECOSCOPE_WORKFLOWS_RESULTS") }}
          filename_suffix: v2
        mapvalues:
          argnames: text
          argvalues: {{ wf("events_bar_chart") }}
      - name: Create Bar Plot Widget for Events
        id: events_bar_chart_widget
        task: create_plot_widget_single_view
        skipif:
          conditions:
            - never
        partial:
          title: {{ wf("set_bar_chart_title") }}
        map:
          argnames:
            - view
            - data
          argvalues: {{ wf("events_bar_chart_html_url") }}
      - name: Merge Bar Plot Widget Views
        id: grouped_bar_plot_widget_merge
        task: merge_widget_views
        partial:
          widgets: {{ wf("events_bar_chart_widget") }}
{% endif %}
{% if map_enabled or tbl_enabled %}
  - name: Rename columns for map tooltip display
    id: rename_display_columns
    task: map_columns
    partial:
      drop_columns: []
      retain_columns: []
      rename_columns:
        serial_number: Event Serial
        time: Event Time
        event_type_display: Event Type
        reported_by_name: Reported By
      raise_if_not_found: true
    mapvalues:
      argnames: df
      argvalues: {{ wf("split_event_groups") }}
{% endif %}
{% if map_enabled or fd_enabled %}
  - name: Map Base Layers
    id: base_map_defs
    task: set_base_maps
{% endif %}
{% if map_enabled %}
  - name: Create map layer from grouped Events
    id: grouped_events_map_layer
    task: create_point_layer
    skipif:
      conditions:
        - any_is_empty_df
        - any_dependency_skipped
        - all_geometry_are_none
    partial:
      layer_style:
        fill_color_column: event_type_colormap
        get_radius: 5
      legend:
        label_column: Event Type
        color_column: event_type_colormap
      tooltip_columns:
        - Event Serial
        - Event Time
        - Event Type
        - Reported By
    mapvalues:
      argnames: geodataframe
      argvalues: {{ wf("rename_display_columns") }}
  - name: Draw Ecomap from grouped Events
    id: grouped_events_ecomap
    task: draw_ecomap
    partial:
      title: null
      tile_layers: {{ wf("base_map_defs") }}
      north_arrow_style:
        placement: top-left
      legend_style:
        title: Event Type
        format_title: false
        placement: bottom-right
      static: false
      max_zoom: 20
      widget_id: {{ wf("set_events_map_title") }}
    mapvalues:
      argnames: geo_layers
      argvalues: {{ wf("grouped_events_map_layer") }}
  - name: Persist grouped Events Ecomap as Text
    id: grouped_events_ecomap_html_url
    task: persist_text
    partial:
      root_path: {{ env("ECOSCOPE_WORKFLOWS_RESULTS") }}
      filename_suffix: v2
    mapvalues:
      argnames: text
      argvalues: {{ wf("grouped_events_ecomap") }}
  - name: Create grouped Events Map Widget
    id: grouped_events_map_widget
    task: create_map_widget_single_view
    skipif:
      conditions:
        - never
    partial:
      title: {{ wf("set_events_map_title") }}
    map:
      argnames:
        - view
        - data
      argvalues: {{ wf("grouped_events_ecomap_html_url") }}
  - name: Merge Events Map Widget Views
    id: grouped_events_map_widget_merge
    task: merge_widget_views
    partial:
      widgets: {{ wf("grouped_events_map_widget") }}
{% endif %}
{% if pie_enabled %}
  - name: Draw Pie Chart for Events
    id: grouped_events_pie_chart
    task: draw_pie_chart
    partial:
      value_column: event_type_display
      color_column: event_type_colormap
      plot_style:
        textinfo: value
      label_column: null
      layout_style: null
      widget_id: {{ wf("set_pie_chart_title") }}
    mapvalues:
      argnames: dataframe
      argvalues: {{ wf("split_event_groups") }}
  - name: Persist Pie Chart as Text
    id: grouped_pie_chart_html_urls
    task: persist_text
    partial:
      root_path: {{ env("ECOSCOPE_WORKFLOWS_RESULTS") }}
      filename_suffix: v2
    mapvalues:
      argnames: text
      argvalues: {{ wf("grouped_events_pie_chart") }}
  - name: Create Plot Widget for Events
    id: grouped_events_pie_chart_widgets
    task: create_plot_widget_single_view
    skipif:
      conditions:
        - never
    partial:
      title: {{ wf("set_pie_chart_title") }}
    map:
      argnames:
        - view
        - data
      argvalues: {{ wf("grouped_pie_chart_html_urls") }}
  - name: Merge Pie Chart Widget Views
    id: grouped_events_pie_widget_merge
    task: merge_widget_views
    partial:
      widgets: {{ wf("grouped_events_pie_chart_widgets") }}
{% endif %}
{% if fd_enabled %}
  - title: {{ event_count_map_title }}
    type: task-group
    description: These settings generate a grid-based heatmap showing where events are concentrated.
    tasks:
      - name: null
        id: events_meshgrid
        task: create_meshgrid
        skipif:
          conditions:
            - any_is_empty_df
            - any_dependency_skipped
            - all_geometry_are_none
        partial:
          aoi: {{ wf("events_add_spatial_index") }}
          intersecting_only: false
      - name: Calculate Event Counts
        id: grouped_events_count_map
        task: calculate_feature_density
        partial:
          meshgrid: {{ wf("events_meshgrid") }}
          geometry_type: point
          sum_column: null
        mapvalues:
          argnames: geodataframe
          argvalues: {{ wf("split_event_groups") }}
      - name: Sort Event Counts By Classification
        id: sort_event_count_values
        task: sort_values
        partial:
          column_name: density
          ascending: true
          na_position: last
        mapvalues:
          argnames: df
          argvalues: {{ wf("grouped_events_count_map") }}
      - name: Drop nan values for map display
        id: drop_nan_values
        task: drop_nan_values_by_column
        partial:
          column_name: density
        mapvalues:
          argnames: df
          argvalues: {{ wf("sort_event_count_values") }}
      - name: Classify Event Count Values
        id: classify_fd
        task: apply_classification
        partial:
          input_column_name: density
          output_column_name: density_bins
          classification_options:
            scheme: equal_interval
            k: 10
          label_options:
            label_ranges: true
            label_decimals: 0
        mapvalues:
          argnames: df
          argvalues: {{ wf("drop_nan_values") }}
      - name: Event Count Colormap
        id: grouped_fd_colormap
        task: apply_color_map
        partial:
          input_column_name: density_bins
          colormap: RdYlGn_r
          output_column_name: density_colormap
        mapvalues:
          argnames: df
          argvalues: {{ wf("classify_fd") }}
      - id: rename_density_output
        task: map_columns
        partial:
          drop_columns: []
          retain_columns: []
          rename_columns:
            density: Count
          raise_if_not_found: true
        mapvalues:
          argnames: df
          argvalues: {{ wf("grouped_fd_colormap") }}
      - name: Create map layer from Event Counts
        id: grouped_fd_map_layer
        task: create_polygon_layer
        skipif:
          conditions:
            - any_is_empty_df
            - any_dependency_skipped
            - all_geometry_are_none
        partial:
          layer_style:
            fill_color_column: density_colormap
            get_line_width: 0
            opacity: 0.400000
          legend:
            label_column: density_bins
            color_column: density_colormap
          tooltip_columns:
            - Count
        mapvalues:
          argnames: geodataframe
          argvalues: {{ wf("rename_density_output") }}
      - name: Draw Ecomap from Event Counts
        id: grouped_fd_ecomap
        task: draw_ecomap
        partial:
          title: null
          tile_layers: {{ wf("base_map_defs") }}
          north_arrow_style:
            placement: top-left
          legend_style:
            title: Number Of Events
            format_title: false
            placement: bottom-right
          static: false
          max_zoom: 20
          widget_id: {{ wf("set_fd_map_title") }}
        mapvalues:
          argnames: geo_layers
          argvalues: {{ wf("grouped_fd_map_layer") }}
      - name: Persist Event Count Ecomap as Text
        id: grouped_fd_ecomap_html_url
        task: persist_text
        partial:
          root_path: {{ env("ECOSCOPE_WORKFLOWS_RESULTS") }}
          filename_suffix: v2
        mapvalues:
          argnames: text
          argvalues: {{ wf("grouped_fd_ecomap") }}
      - name: Create Event Count Map Widget
        id: grouped_fd_map_widget
        task: create_map_widget_single_view
        skipif:
          conditions:
            - never
        partial:
          title: {{ wf("set_fd_map_title") }}
        map:
          argnames:
            - view
            - data
          argvalues: {{ wf("grouped_fd_ecomap_html_url") }}
      - name: Merge Event Count Widget Views
        id: grouped_fd_map_widget_merge
        task: merge_widget_views
        partial:
          widgets: {{ wf("grouped_fd_map_widget") }}
{% endif %}
{% if tbl_enabled %}
  - name: Events Table
    id: events_table
    task: draw_table
    partial:
      columns:
        - Event Serial
        - Event Time
        - Event Type
        - Reported By
      table_config:
        enable_sorting: true
        enable_filtering: false
        enable_download: true
        hide_header: false
      widget_id: {{ wf("set_events_table_title") }}
    mapvalues:
      argnames: dataframe
      argvalues: {{ wf("rename_display_columns") }}
  - name: Persist Events Table as Text
    id: events_table_html_url
    task: persist_text
    partial:
      root_path: {{ env("ECOSCOPE_WORKFLOWS_RESULTS") }}
      filename_suffix: v2
    mapvalues:
      argnames: text
      argvalues: {{ wf("events_table") }}
  - name: Create Table Widget for Events
    id: events_table_single_views
    task: create_table_widget_single_view
    skipif:
      conditions:
        - never
    partial:
      title: {{ wf("set_events_table_title") }}
    map:
      argnames:
        - view
        - data
      argvalues: {{ wf("events_table_html_url") }}
  - name: Merge Table Widget Views
    id: grouped_table_widget_merge
    task: merge_widget_views
    partial:
      widgets: {{ wf("events_table_single_views") }}
{% endif %}
  - name: Create Dashboard with Map Widgets
    id: events_dashboard
    task: gather_dashboard
    partial:
      details: {{ wf("workflow_details") }}
      widgets:
{% if bar_enabled %}
        - {{ wf("grouped_bar_plot_widget_merge") }}
{% endif %}
{% if map_enabled %}
        - {{ wf("grouped_events_map_widget_merge") }}
{% endif %}
{% if pie_enabled %}
        - {{ wf("grouped_events_pie_widget_merge") }}
{% endif %}
{% if fd_enabled %}
        - {{ wf("grouped_fd_map_widget_merge") }}
{% endif %}
{% if tbl_enabled %}
        - {{ wf("grouped_table_widget_merge") }}
{% endif %}
      groupers: {{ wf("resolved_groupers") }}
      time_range: {{ wf("time_range") }}
